---
import type { ReadingEntry } from '../../types/components';
import readingData from '../../data/reading.json';
import { latestReadingHref } from '../../lib/reading';

const entries: ReadingEntry[] = readingData as ReadingEntry[];
const redirectUrl = latestReadingHref(entries);
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />
    <link rel="canonical" href={redirectUrl} />
    <script is:inline define:vars={{ redirectUrl }}>
      window.location.replace(redirectUrl);
    </script>
  </head>
  <body></body>
</html>
